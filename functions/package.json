{
  "name": "functions",
  "version": "1.0.0",
  "description": "Firebase Functions for Avocat LegalTech",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "20"
  },
  "keywords": [
    "firebase",
    "functions",
    "legaltech"
  ],
  "author": "Andres Levano",
  "license": "MIT",
  "dependencies": {
    "@google-cloud/documentai": "^9.5.0",
    "busboy": "^1.6.0",
    "cors": "^2.8.5",
    "docx": "^9.5.1",
    "express": "^4.18.2",
    "firebase-admin": "^13.5.0",
    "firebase-functions": "^7.0.5",
    "jspdf": "^3.0.3",
    "openai": "^6.5.0",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.17.2",
    "stripe": "^14.0.0"
  },
  "devDependencies": {
    "@types/busboy": "^1.5.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^24.8.1",
    "@types/pdf-parse": "^1.1.4",
    "typescript": "^5.9.3"
  }
}
